{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aethra Kairos",
  "version": "0.1.0",
  "identifier": "com.aethrakairos.player",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aethra Kairos",
        "width": 1280,
        "height": 820,
        "minWidth": 480,
        "minHeight": 380,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#05060c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Music",
    "shortDescription": "The open-source label player.",
    "longDescription": "Aethra Kairos — a music player with a live, music-reactive visualizer. Free, in your browser or on your Mac, no login, ever.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kmay89/aethrakairos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCRUE3NEY2RTIxQzI5QUQKUldTdEtSemk5blRxU3pxeHRGdXRaNjRmTzBlZWs1K3VxRnRYODBJOEM4SzMwSzlhdHIzT0tWZjAK"
    }
  }
}
